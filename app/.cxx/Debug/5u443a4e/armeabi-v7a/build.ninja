  DEP_FILE = CMakeFiles\fireplay.dir\fireplay_jni.cpp.o.d
  FLAGS = -g -DANDROID -fdata-sections -ffunction-sections -funwind-tables -fstack-protector-strong -no-canonical-prefixes -D_FORTIFY_SOURCE=2 -march=armv7-a -mthumb -Wformat -Werror=format-security  -std=c++17 -fno-limit-debug-info  -fPIC
  INCLUDES = -IC:/fireplay/app/src/main/cpp/../../../../third_party/alac/codec -IC:/fireplay/app/src/main/cpp/../../../../lib-uxplay -IC:/fireplay/app/src/main/cpp/../../../../lib-uxplay/llhttp -IC:/fireplay/app/src/main/cpp/../../../../lib-uxplay/playfair -IC:/fireplay/app/src/main/cpp/../../../../third_party/android_openssl/ssl_3/include -IC:/fireplay/app/src/main/cpp/../../../../third_party/libplist/include -IC:/fireplay/app/src/main/cpp/../../../../third_party/libplist/src -IC:/fireplay/app/src/main/cpp/../../../../third_party/libplist/libcnary/include
  OBJECT_DIR = CMakeFiles\fireplay.dir
  OBJECT_FILE_DIR = CMakeFiles\fireplay.dir

build CMakeFiles/fireplay.dir/audio_renderer_aaudio.cpp.o: CXX_COMPILER__fireplay_Debug C$:/fireplay/app/src/main/cpp/audio_renderer_aaudio.cpp || cmake_object_order_depends_target_fireplay
