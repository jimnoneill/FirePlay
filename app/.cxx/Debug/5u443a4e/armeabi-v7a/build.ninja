build cmake_object_order_depends_target_fireplay: phony || cmake_object_order_depends_target_airplay cmake_object_order_depends_target_alac_dec cmake_object_order_depends_target_llhttp cmake_object_order_depends_target_playfair cmake_object_order_depends_target_plist

build CMakeFiles/fireplay.dir/fireplay_jni.cpp.o: CXX_COMPILER__fireplay_Debug C$:/fireplay/app/src/main/cpp/fireplay_jni.cpp || cmake_object_order_depends_target_fireplay
