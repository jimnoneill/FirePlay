build airplay: phony libairplay.a

build alac_dec: phony libalac_dec.a

build fireplay: phony C$:/fireplay/app/build/intermediates/cxx/Debug/5u443a4e/obj/armeabi-v7a/libfireplay.so

build libfireplay.so: phony C$:/fireplay/app/build/intermediates/cxx/Debug/5u443a4e/obj/armeabi-v7a/libfireplay.so

build llhttp: phony libllhttp.a

