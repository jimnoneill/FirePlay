build C$:/fireplay/app/build/intermediates/cxx/Debug/5u443a4e/obj/armeabi-v7a/libfireplay.so: CXX_SHARED_LIBRARY_LINKER__fireplay_Debug CMakeFiles/fireplay.dir/fireplay_jni.cpp.o CMakeFiles/fireplay.dir/audio_renderer_aaudio.cpp.o | libairplay.a libalac_dec.a C$:/android/android-ndk-r27d/toolchains/llvm/prebuilt/windows-x86_64/sysroot/usr/lib/arm-linux-androideabi/28/liblog.so C$:/android/android-ndk-r27d/toolchains/llvm/prebuilt/windows-x86_64/sysroot/usr/lib/arm-linux-androideabi/28/libaaudio.so libllhttp.a libplayfair.a libplist.a C$:/fireplay/app/src/main/cpp/../../../../third_party/android_openssl/ssl_3/armeabi-v7a/libcrypto.a || libairplay.a libalac_dec.a libllhttp.a libplayfair.a libplist.a
  LANGUAGE_COMPILE_FLAGS = -g -DANDROID -fdata-sections -ffunction-sections -funwind-tables -fstack-protector-strong -no-canonical-prefixes -D_FORTIFY_SOURCE=2 -march=armv7-a -mthumb -Wformat -Werror=format-security  -std=c++17 -fno-limit-debug-info
  LINK_FLAGS = -static-libstdc++ -Wl,--build-id=sha1 -Wl,--no-rosegment -Wl,--no-undefined-version -Wl,--fatal-warnings -Wl,--no-undefined -Qunused-arguments
  LINK_LIBRARIES = libairplay.a  libalac_dec.a  C:/android/android-ndk-r27d/toolchains/llvm/prebuilt/windows-x86_64/sysroot/usr/lib/arm-linux-androideabi/28/liblog.so  C:/android/android-ndk-r27d/toolchains/llvm/prebuilt/windows-x86_64/sysroot/usr/lib/arm-linux-androideabi/28/libaaudio.so  libllhttp.a  libplayfair.a  libplist.a  C:/fireplay/app/src/main/cpp/../../../../third_party/android_openssl/ssl_3/armeabi-v7a/libcrypto.a  -latomic -lm
  OBJECT_DIR = CMakeFiles\fireplay.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  SONAME = libfireplay.so
  SONAME_FLAG = -Wl,-soname,
  TARGET_FILE = C:\fireplay\app\build\intermediates\cxx\Debug\5u443a4e\obj\armeabi-v7a\libfireplay.so
  TARGET_PDB = fireplay.so.dbg


#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cmd.exe /C "cd /D C:\fireplay\app\.cxx\Debug\5u443a4e\armeabi-v7a && C:\android\sdk\cmake\3.22.1\bin\cmake.exe -E echo "No interactive CMake dialog available.""
  DESC = No interactive CMake dialog available...
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cmd.exe /C "cd /D C:\fireplay\app\.cxx\Debug\5u443a4e\armeabi-v7a && C:\android\sdk\cmake\3.22.1\bin\cmake.exe --regenerate-during-build -SC:\fireplay\app\src\main\cpp -BC:\fireplay\app\.cxx\Debug\5u443a4e\armeabi-v7a"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

